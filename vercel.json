{
  "buildCommand": "vite build && node_modules/.bin/esbuild api/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=api/_bundle.mjs",
  "functions": {
    "api/_bundle.mjs": {}
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/_bundle" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}